# DayFrame environment contract.
# This file is docs-first: it defines the variables the future scaffold must support.

# ------------------------------------------------------------------------------
# Shared runtime variables
# Required locally and in deployed environments.
# ------------------------------------------------------------------------------
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:3000
LOG_LEVEL=info
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
SIGNED_URL_TTL_SECONDS=900
DAY_CONTEXT_TTL_HOURS=24

# ------------------------------------------------------------------------------
# Web app variables
# Required for local web development once apps/web exists.
# ------------------------------------------------------------------------------
WEB_PORT=3000
VITE_APP_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:4000
VITE_DEFAULT_TIMEZONE=Europe/Uzhgorod

# ------------------------------------------------------------------------------
# API service variables
# Required for local API development and all deployed environments.
# ------------------------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
CORS_ALLOWED_ORIGIN=http://localhost:3000
# HttpOnly session cookie that carries the signed JWT for browser-authenticated `/api/*` requests.
# Keep this aligned with the documented API contract (`dayframe_session`) unless the spec is updated too.
SESSION_COOKIE_NAME=dayframe_session

# ------------------------------------------------------------------------------
# Worker variables
# Required for local worker development and all deployed environments.
# The sweep trigger is global, but weekly-issue eligibility must still be computed
# per user timezone according to SPEC.md.
# ------------------------------------------------------------------------------
WORKER_ID=worker-local-1
WORKER_CONCURRENCY=1
JOB_LEASE_TTL_SECONDS=120
JOB_HEARTBEAT_INTERVAL_SECONDS=30
JOB_RECOVERY_SWEEP_INTERVAL_SECONDS=60
PANEL_RENDER_CONCURRENCY=3
WEEKLY_COMPILATION_SWEEP_CRON=*/15 * * * *

# ------------------------------------------------------------------------------
# Database variables
# Required locally and in deployed environments.
# ------------------------------------------------------------------------------
DATABASE_URL=postgres://dayframe:dayframe@localhost:5432/dayframe
DATABASE_SSL_MODE=disable

# ------------------------------------------------------------------------------
# Google OAuth variables
# Optional for local mocked development.
# Required for real local OAuth testing and all deployed environments.
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/callback
GOOGLE_SCOPES=openid,email,profile,https://www.googleapis.com/auth/calendar.readonly,https://www.googleapis.com/auth/tasks.readonly

# ------------------------------------------------------------------------------
# DigitalOcean platform variables
# Optional locally unless deployment checks are run from the workstation.
# Required for deployed environments and demo operations.
# ------------------------------------------------------------------------------
DO_PROJECT_NAME=dayframe
DO_REGION=fra1
DOCTL_CONTEXT=dayframe-hackathon

# ------------------------------------------------------------------------------
# Spaces variables
# Optional for mocked local media flows.
# Required for real media storage and all deployed environments.
# ------------------------------------------------------------------------------
DO_SPACES_BUCKET=dayframe-media
DO_SPACES_REGION=fra1
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
DO_SPACES_CDN_BASE_URL=
DO_ACCESS_KEY_ID=your-digitalocean-access-key
DO_SECRET_ACCESS_KEY=your-digitalocean-secret-key

# ------------------------------------------------------------------------------
# Gemini image generation variables
# Optional for mocked local rendering.
# Required for real panel rendering and all deployed environments.
# ------------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
GEMINI_REQUEST_TIMEOUT_MS=30000

# ------------------------------------------------------------------------------
# Private model variables
# Optional while Agent 1 runs the mocked script provider.
# Required for real model integration and all deployed environments.
# ------------------------------------------------------------------------------
PRIVATE_MODEL_BASE_URL=http://10.0.0.10:8000
PRIVATE_MODEL_API_KEY=replace-with-private-model-token
PRIVATE_MODEL_TIMEOUT_MS=10000
PRIVATE_MODEL_MODE=non-thinking
